{
  "name": "silver-stream-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create silver-stream-db",
    "db:migrate": "wrangler d1 migrations apply silver-stream-db",
    "db:migrate:local": "wrangler d1 migrations apply silver-stream-db --local",
    "storage:create": "wrangler r2 bucket create silver-stream-storage"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^0.38.3",
    "@clerk/backend": "^1.28.3"
  },
  "devDependencies": {
    "wrangler": "^3.99.0",
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "~5.9.3"
  }
}
